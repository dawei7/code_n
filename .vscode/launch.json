{
  // VSCode debug + run configurations for cOde(n).
  //
  // The player writes their solution in solutions/<id>.py and
  // edits it in VSCode. Press F5 to run it under debugpy against
  // the cOde(n) engine (the same engine cOde(n) uses). The verdict
  // and complexity numbers print in the integrated terminal;
  // breakpoints you set in solutions/<id>.py hit normally.
  //
  // cOde(n)'s "Open in VSCode" button writes the active
  // challenge id to solutions/.vscode-active. The script reads
  // that file when no id is passed, so the typical flow is:
  //   1. Open cOde(n), pick a challenge
  //   2. Click "Open in VSCode" -> VSCode opens the project
  //   3. In VSCode: open solutions/<id>.py, press F5
  //   4. If you change challenges in cOde(n), click "Open in
  //      VSCode" again to refresh the active file
  //
  // Working directory: the repo root. Python interpreter: the
  // .venv at the repo root. Both are configured in settings.json.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run current challenge (debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/run_solution.py",
      "args": [
        "${input:challengeId}",
        "--n", "${input:n}",
        "--seed", "${input:seed}",
        "--no-ansi"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "purpose": ["debug-test"]
    },
    {
      "name": "Run current challenge (no debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/run_solution.py",
      "args": [
        "${input:challengeId}",
        "--n", "${input:n}",
        "--seed", "${input:seed}",
        "--no-ansi"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "purpose": ["debug-test"],
      "presentation": {
        "hidden": false
      }
    }
  ],
  "inputs": [
    {
      "id": "challengeId",
      "type": "command",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe ${workspaceFolder}/.vscode/get_active_challenge.py",
      "description": "Active challenge id from cOde(n) (solutions/.vscode-active); falls back to most-recently-modified solutions/*.py"
    },
    {
      "id": "n",
      "type": "promptString",
      "description": "Input size n (max depends on the challenge - see the description in cOde(n))",
      "default": "16"
    },
    {
      "id": "seed",
      "type": "promptString",
      "description": "Random seed (any integer)",
      "default": "1"
    }
  ]
}
