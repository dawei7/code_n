# Python venv + bytecode
.venv/
__pycache__/
*.py[cod]
*$py.class

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PyInstaller outputs
build/
dist/
*.spec

# Packaging metadata
*.egg-info/

# Local environment
.env
.env.*

# Player save file - regenerated by cOde(n) the first time it runs.
# See progress.example.json for the schema.
progress.json
logs/

# Web frontend (React + Vite)
web/node_modules/
web/dist/
web/.vite/
web/*.tsbuildinfo
web/vite.config.d.ts
web/vite.config.js
# Stray tsc emits under src/types/ (the only legitimate
# .ts file there is electron.ts). The web project uses
# noEmit but project-references builds (tsc -b) can still
# drop .js next to .ts in some configurations.
web/src/types/*.js

# Electron desktop wrapper
electron/node_modules/
electron/dist/
electron/release/

# Server build artifacts (PyInstaller bundling)
server/dist/
server/build/

# bundled-workspace/ is the per-user VSCode workspace template
# staged at build time. Only the hand-written .vscode/ subdir
# is checked in (it's a different config from the dev
# .vscode/); the rest (tools/, server/, code_n/, challenges/)
# is auto-generated by `python build_app.py` from the repo
# source and is gitignored. The Electron main process copies
# the whole tree into the user's appData dir on first launch.
bundled-workspace/tools/
bundled-workspace/server/
bundled-workspace/code_n/
bundled-workspace/challenges/

# Editor caches
.idea/

# The cOde(n)-specific VSCode files (launch.json + tasks.json +
# settings.json) are committed — they're the in-VSCode equivalent
# of the cOde(n) app's buttons. Everything else under .vscode/ is
# local workspace state (extensions, recents, the per-developer
# handoff file the "Open in VSCode" button writes) and stays out
# of git.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json
solutions/.vscode-active

# Chromium / Electron crash logs (not from our code)
debug.log
*.log
*.main.js

# Stray main.js in electron/ from asar extraction (electron/main.js is not a real source file)
