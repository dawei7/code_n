# Python venv + bytecode
.venv/
__pycache__/
*.py[cod]
*$py.class

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PyInstaller outputs
build/
dist/
*.spec

# Packaging metadata
*.egg-info/

# Local environment
.env
.env.*

# Player save file - regenerated by cOde(n) the first time it runs.
# See progress.example.json for the schema.
progress.json
logs/

# Web frontend (React + Vite)
web/node_modules/
web/dist/
web/.vite/
web/*.tsbuildinfo
web/vite.config.d.ts
web/vite.config.js

# Electron desktop wrapper
electron/node_modules/
electron/dist/
electron/release/

# Server build artifacts (PyInstaller bundling)
server/dist/
server/build/

# Editor caches
.idea/
.vscode/

# Chromium / Electron crash logs (not from our code)
debug.log
*.log
