  "schema_version": 1,
  "challenge_id": "lc_1707",
  "cases": [
    {"id":"sample-growing-limits","name":"sample: growing limits admit progressively more numbers","kind":"sample","visible":true,"input":{"nums":[0,1,2,3,4],"queries":[[3,1],[1,3],[5,6]]},"expected":[3,3,7],"tags":["sample","limits"]},
    {"id":"sample-empty-query","name":"sample: one query has no eligible value","kind":"sample","visible":true,"input":{"nums":[5,2,4,6,6,3],"queries":[[12,4],[8,1],[6,3]]},"expected":[15,-1,5],"tags":["sample","no-eligible"]},
    {"id":"trial-threshold-growth","name":"trial: threshold equality admits each new value","kind":"trial","visible":true,"input":{"nums":[1,7,9],"queries":[[4,0],[4,8],[4,10]]},"expected":[-1,5,13],"tags":["threshold","equality"]},
    {"id":"trial-zero-only","name":"trial: zero can be the sole eligible partner","kind":"trial","visible":true,"input":{"nums":[0],"queries":[[0,0],[5,0]]},"expected":[0,5],"tags":["zero","single-number"]},
    {"id":"trial-duplicates","name":"trial: duplicate numbers do not change the maximum","kind":"trial","visible":true,"input":{"nums":[2,2,2],"queries":[[7,2],[0,1]]},"expected":[5,-1],"tags":["duplicates","no-eligible"]},
    {"id":"trial-original-order","name":"trial: descending limits still return original query order","kind":"trial","visible":true,"input":{"nums":[0,4,7],"queries":[[3,7],[3,0],[3,4]]},"expected":[7,3,7],"tags":["query-order","offline-sort"]},
    {"id":"real-high-bit","name":"hidden: the highest supported bit controls the optimum","kind":"real","visible":false,"input":{"nums":[0,536870912,1000000000],"queries":[[1,1000000000],[536870912,536870912]]},"expected":[1000000001,536870912],"tags":["high-bit","maximum-value"]},
    {"id":"real-limit-equality","name":"hidden: a value equal to the limit is eligible","kind":"real","visible":false,"input":{"nums":[3,10],"queries":[[5,3],[5,2]]},"expected":[6,-1],"tags":["equality","boundary"]},
    {"id":"real-repeated-queries","name":"hidden: repeated queries preserve duplicate outputs","kind":"real","visible":false,"input":{"nums":[1,2,8],"queries":[[7,8],[7,8],[7,1]]},"expected":[15,15,6],"tags":["duplicates","query-order"]},
    {"id":"real-prefer-significant-bit","name":"hidden: significant differing bit beats lower-bit gains","kind":"real","visible":false,"input":{"nums":[7,8,15],"queries":[[8,15],[14,8]]},"expected":[15,9],"tags":["bit-greedy","significance"]}
  ]
