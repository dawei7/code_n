{
  "schema_version": 1,
  "challenge_id": "lc_2092",
  "cases": [
    {
      "id": "sample-chronological-chain",
      "name": "sample: knowledge propagates through later meetings",
      "kind": "sample",
      "visible": true,
      "input": {
        "n": 6,
        "meetings": [[1, 2, 5], [2, 3, 8], [1, 5, 10]],
        "firstPerson": 1
      },
      "expected": [0, 1, 2, 3, 5],
      "validator": {"kind": "unordered_list"},
      "tags": ["sample", "chronological"]
    },
    {
      "id": "sample-earlier-meeting-does-not-persist",
      "name": "sample: uninformed historical edge is discarded",
      "kind": "sample",
      "visible": true,
      "input": {
        "n": 4,
        "meetings": [[3, 1, 3], [1, 2, 2], [0, 3, 3]],
        "firstPerson": 3
      },
      "expected": [0, 1, 3],
      "validator": {"kind": "unordered_list"},
      "tags": ["sample", "no-retroactive-sharing"]
    },
    {
      "id": "sample-instantaneous-same-time-chain",
      "name": "sample: newly informed person shares at the same time",
      "kind": "sample",
      "visible": true,
      "input": {
        "n": 5,
        "meetings": [[3, 4, 2], [1, 2, 1], [2, 3, 1]],
        "firstPerson": 1
      },
      "expected": [0, 1, 2, 3, 4],
      "validator": {"kind": "unordered_list"},
      "tags": ["sample", "instantaneous-chain"]
    },
    {
      "id": "trial-no-reachable-meeting",
      "name": "meetings disconnected from both initial knowers transmit nothing",
      "kind": "trial",
      "visible": true,
      "input": {
        "n": 5,
        "meetings": [[2, 3, 1], [3, 4, 2]],
        "firstPerson": 1
      },
      "expected": [0, 1],
      "validator": {"kind": "unordered_list"},
      "tags": ["disconnected"]
    },
    {
      "id": "real-reversed-same-time-order",
      "name": "hidden: input order cannot block same-time closure",
      "kind": "real",
      "visible": false,
      "input": {
        "n": 6,
        "meetings": [[4, 5, 7], [3, 4, 7], [2, 3, 7], [1, 2, 7]],
        "firstPerson": 1
      },
      "expected": [0, 1, 2, 3, 4, 5],
      "validator": {"kind": "unordered_list"},
      "tags": ["hidden", "same-time", "adversarial-order"]
    },
    {
      "id": "real-separate-components-one-seeded",
      "name": "hidden: only a seeded component learns within a time batch",
      "kind": "real",
      "visible": false,
      "input": {
        "n": 8,
        "meetings": [[1, 2, 4], [2, 3, 4], [4, 5, 4], [5, 6, 4]],
        "firstPerson": 1
      },
      "expected": [0, 1, 2, 3],
      "validator": {"kind": "unordered_list"},
      "tags": ["hidden", "multiple-components"]
    },
    {
      "id": "real-late-seeding-no-retroactivity",
      "name": "hidden: later knowledge cannot traverse an old component",
      "kind": "real",
      "visible": false,
      "input": {
        "n": 6,
        "meetings": [[2, 3, 1], [3, 4, 1], [1, 2, 2]],
        "firstPerson": 1
      },
      "expected": [0, 1, 2],
      "validator": {"kind": "unordered_list"},
      "tags": ["hidden", "late-seed"]
    }
  ]
}
