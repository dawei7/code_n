{
  "schema_version": 1,
  "challenge_id": "lc_2082",
  "cases": [
    {
      "id": "sample-two-rich-customers",
      "name": "sample: duplicate qualifying bills count one customer once",
      "kind": "sample",
      "visible": true,
      "input": {
        "tables": {
          "Store": [
            {"bill_id": 6, "customer_id": 1, "amount": 549},
            {"bill_id": 8, "customer_id": 1, "amount": 834},
            {"bill_id": 4, "customer_id": 2, "amount": 394},
            {"bill_id": 11, "customer_id": 3, "amount": 657},
            {"bill_id": 13, "customer_id": 3, "amount": 257}
          ]
        }
      },
      "expected": {"columns": ["rich_count"], "rows": [[2]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["sample", "distinct-customers"]
    },
    {
      "id": "trial-strict-threshold",
      "name": "an amount equal to five hundred does not qualify",
      "kind": "trial",
      "visible": true,
      "input": {
        "tables": {
          "Store": [
            {"bill_id": 1, "customer_id": 7, "amount": 500},
            {"bill_id": 2, "customer_id": 8, "amount": 501}
          ]
        }
      },
      "expected": {"columns": ["rich_count"], "rows": [[1]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["strict-threshold"]
    },
    {
      "id": "trial-one-qualifying-bill",
      "name": "one qualifying bill is sufficient among mixed amounts",
      "kind": "trial",
      "visible": true,
      "input": {
        "tables": {
          "Store": [
            {"bill_id": 1, "customer_id": 4, "amount": 100},
            {"bill_id": 2, "customer_id": 4, "amount": 900},
            {"bill_id": 3, "customer_id": 5, "amount": 300}
          ]
        }
      },
      "expected": {"columns": ["rich_count"], "rows": [[1]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["mixed-bills"]
    },
    {
      "id": "real-no-rich-customers",
