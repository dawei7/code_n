{
  "schema_version": 1,
  "challenge_id": "lc_2046",
  "cases": [
    {
      "id": "sample-mixed-signs",
      "name": "sample: negative nodes move ahead in reverse encounter order",
      "kind": "sample",
      "visible": true,
      "input": {"head": [0, 2, -5, 5, 10, -10]},
      "expected": [-10, -5, 0, 2, 5, 10],
      "tags": ["sample", "mixed-sign"]
    },
    {
      "id": "sample-already-sorted",
      "name": "sample: an all-nonnegative list is unchanged",
      "kind": "sample",
      "visible": true,
      "input": {"head": [0, 1, 2]},
      "expected": [0, 1, 2],
      "tags": ["sample", "already-sorted"]
    },
    {
      "id": "sample-single-node",
      "name": "sample: one node is already sorted",
      "kind": "sample",
      "visible": true,
      "input": {"head": [1]},
      "expected": [1],
      "tags": ["sample", "minimum-length"]
    },
    {
      "id": "trial-all-negative",
      "name": "an all-negative absolute ordering must be reversed",
      "kind": "trial",
      "visible": true,
      "input": {"head": [-1, -2, -3]},
      "expected": [-3, -2, -1],
      "tags": ["all-negative", "reverse"]
    },
    {
      "id": "trial-equal-magnitude-order",
      "name": "a negative tied magnitude moves before its positive peer",
      "kind": "trial",
      "visible": true,
      "input": {"head": [2, -2]},
      "expected": [-2, 2],
      "tags": ["equal-absolute-value", "tie"]
    },
    {
      "id": "real-zero-and-negatives",
      "name": "hidden: zero stays after every moved negative",
      "kind": "real",
      "visible": false,
      "input": {"head": [0, -1, 1, -2, 3]},
      "expected": [-2, -1, 0, 1, 3],
      "tags": ["hidden", "zero", "mixed-sign"]
    },
    {
      "id": "real-duplicate-negatives",
      "name": "hidden: duplicate negative values remain valid nodes",
      "kind": "real",
      "visible": false,
      "input": {"head": [-1, -1, 2, -2]},
      "expected": [-2, -1, -1, 2],
      "tags": ["hidden", "duplicates", "ties"]
    },
    {
      "id": "real-value-boundaries",
      "name": "hidden: both signed value limits",
      "kind": "real",
      "visible": false,
      "input": {"head": [-5000, 5000]},
      "expected": [-5000, 5000],
      "tags": ["hidden", "value-boundary"]
    }
  ]
}
