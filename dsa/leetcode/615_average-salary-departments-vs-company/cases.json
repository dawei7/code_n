        "Employee": [{"employee_id": 1, "department_id": 1}, {"employee_id": 2, "department_id": 2}, {"employee_id": 3, "department_id": 2}]
      }},
      "expected": {"columns": ["pay_month", "department_id", "comparison"], "rows": [["2017-02", 1, "same"], ["2017-02", 2, "same"], ["2017-03", 1, "higher"], ["2017-03", 2, "lower"]]},
