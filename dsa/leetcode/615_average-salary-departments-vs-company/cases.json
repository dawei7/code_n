    },
    {"id": "sample-2", "name": "sample: one department equals company", "kind": "sample", "visible": true, "input": {"tables": {"Salary": [{"id": 1, "employee_id": 1, "amount": 5000, "pay_date": "2020-01-31"}, {"id": 2, "employee_id": 2, "amount": 7000, "pay_date": "2020-01-31"}], "Employee": [{"employee_id": 1, "department_id": 9}, {"employee_id": 2, "department_id": 9}]}}, "expected": {"columns": ["pay_month", "department_id", "comparison"], "rows": [["2020-01", 9, "same"]]}, "tags": ["sample", "single-department"]},
    {"id": "sample-3", "name": "sample: two single-person departments", "kind": "sample", "visible": true, "input": {"tables": {"Salary": [{"id": 1, "employee_id": 1, "amount": 100, "pay_date": "2021-05-01"}, {"id": 2, "employee_id": 2, "amount": 300, "pay_date": "2021-05-20"}], "Employee": [{"employee_id": 1, "department_id": 1}, {"employee_id": 2, "department_id": 2}]}}, "expected": {"columns": ["pay_month", "department_id", "comparison"], "rows": [["2021-05", 1, "lower"], ["2021-05", 2, "higher"]]}, "tags": ["sample", "two-departments"]},
