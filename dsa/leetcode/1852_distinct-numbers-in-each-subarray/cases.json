    {"id":"example-growing-variety","name":"sample: repeated prefix gives way to new values","kind":"sample","visible":true,"input":{"args":[[1,1,1,1,2,3,4],4]},"expected":[1,2,3,4],"validator":{"kind":"exact"},"tags":["example","duplicates"]},
    {"id":"trial-window-one","name":"window length one always has one distinct value","kind":"trial","visible":true,"input":{"args":[[5,5,5],1]},"expected":[1,1,1],"validator":{"kind":"exact"},"tags":["minimum-window"]},
    {"id":"real-whole-array","name":"hidden: a full-length window produces one answer","kind":"real","visible":false,"input":{"args":[[4,1,4,2,1],5]},"expected":[3],"validator":{"kind":"exact"},"tags":["whole-array"]},
    {"id":"real-all-equal","name":"hidden: all windows contain one repeated value","kind":"real","visible":false,"input":{"args":[[7,7,7,7,7],3]},"expected":[1,1,1],"validator":{"kind":"exact"},"tags":["all-equal"]},
    {"id":"real-enter-and-leave","name":"hidden: last occurrences leave while new values enter","kind":"real","visible":false,"input":{"args":[[1,2,1,3,2,3],3]},"expected":[2,3,3,2],"validator":{"kind":"exact"},"tags":["frequency-updates"]},
    {"id":"real-outgoing-duplicate","name":"hidden: removing one duplicate does not remove its key","kind":"real","visible":false,"input":{"args":[[5,5,6,5,6,7],2]},"expected":[1,2,2,2,2],"validator":{"kind":"exact"},"tags":["outgoing-duplicate"]},
    {"id":"real-value-boundary","name":"hidden: maximum values behave like ordinary keys","kind":"real","visible":false,"input":{"args":[[100000,1,100000,2],2]},"expected":[2,2,2],"validator":{"kind":"exact"},"tags":["value-boundary"]},
    {"id":"real-distinct-to-equal","name":"hidden: a window can shrink to one distinct value then grow","kind":"real","visible":false,"input":{"args":[[1,2,2,3],2]},"expected":[2,1,2],"validator":{"kind":"exact"},"tags":["zero-count-removal"]},
    {"id":"real-all-distinct","name":"hidden: every fixed window contains only unique values","kind":"real","visible":false,"input":{"args":[[1,2,3,4,5,6],4]},"expected":[4,4,4],"validator":{"kind":"exact"},"tags":["all-distinct"]}
