      "visible": true,
      "input": {"intervals": [[1, 2]]},
      "expected": [-1],
      "tags": ["sample", "single"]
    },
    {
      "id": "sample-2",
      "name": "sample: reversed chain of exact endpoint matches",
      "kind": "sample",
      "visible": true,
      "input": {"intervals": [[3, 4], [2, 3], [1, 2]]},
      "expected": [-1, 0, 1],
      "tags": ["sample", "chain"]
    },
    {
      "id": "sample-3",
      "name": "sample: only the middle interval has a right neighbor",
      "kind": "sample",
      "visible": true,
      "input": {"intervals": [[1, 4], [2, 3], [3, 4]]},
      "expected": [-1, 2, -1],
      "tags": ["sample", "mixed"]
    },
    {
      "id": "trial-negative",
      "name": "trial: negative endpoints and exact matches",
      "kind": "trial",
      "visible": true,
      "input": {"intervals": [[-5, -3], [-3, -1], [0, 2]]},
      "expected": [1, 2, -1],
      "tags": ["trial", "negative"]
    },
    {
      "id": "trial-gaps",
      "name": "trial: lower bound skips several small starts",
      "kind": "trial",
      "visible": true,
      "input": {"intervals": [[0, 7], [2, 3], [5, 6], [9, 10]]},
      "expected": [3, 2, 3, -1],
      "tags": ["trial", "gaps"]
    },
    {
      "id": "hidden-unsorted",
      "name": "hidden: original positions differ from start order",
      "kind": "real",
      "visible": false,
      "input": {"intervals": [[10, 11], [1, 4], [7, 8], [4, 7]]},
      "expected": [-1, 3, 0, 2],
      "tags": ["hidden", "indices"]
    },
    {
      "id": "hidden-none",
      "name": "hidden: every interval ends beyond the largest start",
      "kind": "real",
      "visible": false,
      "input": {"intervals": [[1, 100], [2, 99], [3, 98]]},
      "expected": [-1, -1, -1],
      "tags": ["hidden", "none"]
    }
  ]
