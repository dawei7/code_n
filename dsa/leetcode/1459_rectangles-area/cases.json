      ]}},
      "expected": {"columns": ["p1", "p2", "area"], "rows": [[1, 3, 20]]},
      "tags": ["trial", "degenerate-pairs"]
    },
    {
      "id": "trial-tied-areas",
      "name": "equal areas use both ascending ID tie-breakers",
      "kind": "trial",
      "visible": true,
      "input": {"tables": {"Points": [
        {"id": 1, "x_value": 0, "y_value": 0},
        {"id": 2, "x_value": 1, "y_value": 1},
        {"id": 3, "x_value": 2, "y_value": 0},
        {"id": 4, "x_value": 1, "y_value": -1}
      ]}},
      "expected": {"columns": ["p1", "p2", "area"], "rows": [
        [1, 2, 1], [1, 4, 1], [2, 3, 1], [3, 4, 1]
      ]},
      "tags": ["trial", "tie-ordering"]
    },
