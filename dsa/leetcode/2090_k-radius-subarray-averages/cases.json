      "expected": [100000],
      "tags": ["sample", "zero-radius"]
    },
    {
      "id": "sample-radius-too-large",
      "name": "sample: no complete window fits",
      "kind": "sample",
      "visible": true,
      "input": {"nums": [8], "k": 100000},
      "expected": [-1],
      "tags": ["sample", "oversized-radius"]
    },
    {
      "id": "trial-whole-array-window",
      "name": "exactly one center averages the whole array",
      "kind": "trial",
      "visible": true,
      "input": {"nums": [2, 3, 1, 5, 4], "k": 2},
      "expected": [-1, -1, 3, -1, -1],
