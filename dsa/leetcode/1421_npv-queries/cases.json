    {
      "id": "sample-mixed",
      "name": "sample: stored and missing values",
      "kind": "sample",
      "visible": true,
      "input": {
        "tables": {
          "NPV": [
            {
              "id": 1,
              "year": 2018,
              "npv": 100
            },
            {
              "id": 1,
              "year": 2019,
              "npv": 113
            },
            {
              "id": 7,
              "year": 2019,
              "npv": 0
            },
            {
              "id": 7,
              "year": 2020,
              "npv": 30
            }
          ],
          "Queries": [
            {
              "id": 1,
              "year": 2019
            },
            {
              "id": 7,
              "year": 2018
            },
            {
              "id": 7,
              "year": 2019
            },
            {
              "id": 7,
              "year": 2020
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "id",
          "year",
          "npv"
        ],
        "rows": [
          [
            1,
            2019,
            113
          ],
          [
            7,
            2018,
            0
          ],
          [
            7,
            2019,
            0
          ],
          [
            7,
            2020,
            30
          ]
        ]
      },
      "tags": [
        "sample",
        "missing"
      ]
    },
