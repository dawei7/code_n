        "Chests":[{"chest_id":2,"apple_count":3,"orange_count":4},{"chest_id":99,"apple_count":1000,"orange_count":1000}]
      }},
      "expected":{"columns":["apple_count","orange_count"],"rows":[[9,9]]},
