{"schema_version":1,"challenge_id":"lc_1089","cases":[{"id":"sample-1","name":"sample: duplicate middle zeros","kind":"sample","visible":true,"input":{"arr":[1,0,2,3,0,4,5,0]},"expected":[1,0,0,2,3,0,0,4],"tags":["sample","shifting"]},{"id":"sample-2","name":"sample: no zeros","kind":"sample","visible":true,"input":{"arr":[1,2,3]},"expected":[1,2,3],"tags":["sample","unchanged"]},{"id":"trial-single-zero","name":"single zero remains one zero","kind":"trial","visible":true,"input":{"arr":[0]},"expected":[0],"tags":["trial","single"]},{"id":"trial-boundary-zero","name":"zero whose duplicate crosses boundary","kind":"trial","visible":true,"input":{"arr":[1,2,3,0]},"expected":[1,2,3,0],"tags":["trial","boundary"]},{"id":"real-partial-shift","name":"hidden: boundary duplication replaces trailing value","kind":"real","visible":false,"input":{"arr":[1,2,0,3]},"expected":[1,2,0,0],"tags":["hidden","boundary"]},{"id":"real-leading-zeros","name":"hidden: consecutive leading zeros","kind":"real","visible":false,"input":{"arr":[0,0,1,2,3]},"expected":[0,0,0,0,1],"tags":["hidden","consecutive"]},{"id":"real-all-zeros","name":"hidden: all zeros remain zeros","kind":"real","visible":false,"input":{"arr":[0,0,0,0,0]},"expected":[0,0,0,0,0],"tags":["hidden","all-zero"]},{"id":"real-interleaved","name":"hidden: several separated duplicates","kind":"real","visible":false,"input":{"arr":[0,1,0,2,0,3]},"expected":[0,0,1,0,0,2],"tags":["hidden","interleaved"]}]}
