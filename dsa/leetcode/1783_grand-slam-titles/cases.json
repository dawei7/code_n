    {
      "id": "real-repeated-champion",
      "name": "hidden: title count accumulates across every column and year",
      "kind": "real",
      "visible": false,
      "input": {"tables": {
        "Players": [
          {"player_id": 6, "player_name": "Repeat"},
          {"player_id": 11, "player_name": "Other"},
          {"player_id": 12, "player_name": "Never"}
        ],
        "Championships": [
          {"year": 2010, "Wimbledon": 6, "Fr_open": 11, "US_open": 6, "Au_open": 6},
          {"year": 2011, "Wimbledon": 6, "Fr_open": 6, "US_open": 11, "Au_open": 6},
          {"year": 2012, "Wimbledon": 11, "Fr_open": 6, "US_open": 6, "Au_open": 11}
        ]
      }},
      "expected": {"columns": ["player_id", "player_name", "grand_slams_count"], "rows": [[6,"Repeat",8],[11,"Other",4]]},
