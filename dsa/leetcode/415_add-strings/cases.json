      },
      "expected": "0",
      "tags": [
        "sample",
        "zero"
      ]
    },
    {
      "id": "trial-final-carry",
      "name": "trial: carry creates a new leading digit",
      "kind": "trial",
      "visible": true,
      "input": {
        "num1": "999",
        "num2": "1"
      },
      "expected": "1000",
      "tags": [
        "trial",
        "final-carry"
      ]
    },
    {
      "id": "trial-longer-second",
      "name": "trial: second input has a long prefix",
      "kind": "trial",
      "visible": true,
      "input": {
        "num1": "5",
        "num2": "100000"
      },
      "expected": "100005",
      "tags": [
        "trial",
        "unequal"
      ]
    },
    {
      "id": "hidden-many-carries",
      "name": "hidden: carry propagates through both inputs",
      "kind": "real",
      "visible": false,
      "input": {
        "num1": "999999999",
        "num2": "999999999"
      },
      "expected": "1999999998",
      "tags": [
        "hidden",
        "many-carries"
      ]
    },
    {
      "id": "hidden-no-carry",
      "name": "hidden: aligned digits add independently",
      "kind": "real",
      "visible": false,
      "input": {
        "num1": "123456789",
