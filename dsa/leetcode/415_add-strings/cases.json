      },
      "expected": "134",
      "tags": [
        "sample",
        "unequal"
      ]
    },
    {
      "id": "sample-2",
      "name": "sample: carry within the sum",
      "kind": "sample",
      "visible": true,
      "input": {
        "num1": "456",
        "num2": "77"
      },
      "expected": "533",
      "tags": [
        "sample",
        "carry"
      ]
    },
    {
      "id": "sample-3",
      "name": "sample: both values are zero",
      "kind": "sample",
      "visible": true,
      "input": {
        "num1": "0",
