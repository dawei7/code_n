{
  "schema_version": 1,
  "challenge_id": "lc_1762",
  "cases": [
    {
      "id": "sample-mixed-heights",
      "name": "sample: several separated buildings see the ocean",
      "kind": "sample",
      "visible": true,
      "input": {"heights": [4, 2, 3, 1]},
      "expected": [0, 2, 3],
      "tags": ["sample", "mixed-heights"]
    },
    {
      "id": "sample-decreasing",
      "name": "sample: every decreasing building is visible",
      "kind": "sample",
      "visible": true,
      "input": {"heights": [4, 3, 2, 1]},
      "expected": [0, 1, 2, 3],
      "tags": ["sample", "strictly-decreasing", "all-visible"]
    },
    {
      "id": "sample-increasing-peak",
      "name": "sample: final peak blocks every predecessor",
      "kind": "sample",
      "visible": true,
      "input": {"heights": [1, 3, 2, 4]},
      "expected": [3],
      "tags": ["sample", "final-maximum"]
    },
    {
      "id": "trial-single-building",
      "name": "trial: one building faces the ocean",
      "kind": "trial",
      "visible": true,
      "input": {"heights": [7]},
      "expected": [0],
      "tags": ["minimum-length", "last-building"]
    },
    {
      "id": "trial-equal-heights",
      "name": "trial: equal heights block one another",
      "kind": "trial",
      "visible": true,
      "input": {"heights": [2, 2, 2, 2]},
      "expected": [3],
      "tags": ["duplicates", "strict-comparison"]
    },
    {
      "id": "real-equal-middle-peaks",
      "name": "hidden: only the rightmost equal peak survives",
      "kind": "real",
      "visible": false,
      "input": {"heights": [3, 5, 4, 4, 3]},
      "expected": [1, 3, 4],
      "tags": ["duplicates", "middle-peak"]
    },
    {
      "id": "real-descending-peaks",
      "name": "hidden: separated descending peaks remain visible",
      "kind": "real",
      "visible": false,
      "input": {"heights": [10, 1, 9, 2, 8]},
      "expected": [0, 2, 4],
      "tags": ["separated-peaks", "suffix-maximum"]
    },
    {
      "id": "real-strictly-increasing",
      "name": "hidden: only the last of increasing buildings qualifies",
      "kind": "real",
      "visible": false,
      "input": {"heights": [1, 2, 3, 4, 5, 6]},
      "expected": [5],
      "tags": ["strictly-increasing", "last-building"]
    }
  ]
}
