{
  "schema_version": 1,
  "challenge_id": "lc_721",
  "measurement_note": "Size is the number of account records and unique emails. Every record is disconnected despite sharing the same display name. Email-indexed union-find processes them linearly apart from output sorting, while comparing every pair of account email sets performs quadratic work even when no merge occurs.",
  "cases": [
    {
      "id": "benchmark-scale-1",
      "name": "benchmark: 8 disconnected accounts",
      "kind": "benchmark",
      "visible": false,
      "size": 8,
      "input": {"accounts": [
        ["User","e000@x.com"],["User","e001@x.com"],["User","e002@x.com"],["User","e003@x.com"],
        ["User","e004@x.com"],["User","e005@x.com"],["User","e006@x.com"],["User","e007@x.com"]
      ]},
      "expected": [
        ["User","e000@x.com"],["User","e001@x.com"],["User","e002@x.com"],["User","e003@x.com"],
        ["User","e004@x.com"],["User","e005@x.com"],["User","e006@x.com"],["User","e007@x.com"]
      ],
      "validator": {"kind": "accounts_merge"},
      "tags": ["benchmark", "scaling", "pairwise-intersection"]
    },
