{
  "schema_version": 1,
  "challenge_id": "lc_1369",
  "cases": [
    {
      "id": "sample-mixed-history",
      "name": "sample: one multi-activity and one single-activity user",
      "kind": "sample",
      "visible": true,
      "input": {
        "tables": {
          "UserActivity": [
            {
              "username": "Alice",
              "activity": "Reading",
              "startDate": "2020-01-01",
              "endDate": "2020-01-02"
            },
            {
              "username": "Alice",
              "activity": "Hiking",
              "startDate": "2020-02-10",
              "endDate": "2020-02-12"
            },
            {
              "username": "Alice",
              "activity": "Coding",
              "startDate": "2020-03-20",
              "endDate": "2020-03-21"
            },
            {
              "username": "Bob",
              "activity": "Swimming",
              "startDate": "2020-04-01",
              "endDate": "2020-04-03"
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "username",
          "activity",
          "startDate",
          "endDate"
        ],
        "rows": [
          [
            "Alice",
            "Hiking",
            "2020-02-10",
            "2020-02-12"
          ],
          [
            "Bob",
            "Swimming",
            "2020-04-01",
            "2020-04-03"
          ]
        ]
      },
      "tags": [
        "sample",
        "fallback"
      ]
    },
    {
      "id": "sample-exactly-two",
      "name": "sample: exactly two activities returns older",
      "kind": "sample",
      "visible": true,
      "input": {
        "tables": {
          "UserActivity": [
            {
              "username": "Cara",
              "activity": "New",
              "startDate": "2022-06-10",
              "endDate": "2022-06-11"
            },
            {
              "username": "Cara",
              "activity": "Old",
              "startDate": "2021-05-01",
              "endDate": "2021-05-02"
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "username",
          "activity",
          "startDate",
          "endDate"
        ],
        "rows": [
          [
            "Cara",
            "Old",
            "2021-05-01",
            "2021-05-02"
          ]
        ]
      },
      "tags": [
        "sample",
        "two-activities"
      ]
    },
