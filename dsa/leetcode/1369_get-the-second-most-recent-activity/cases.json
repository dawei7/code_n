    {
      "id": "trial-scrambled-input",
      "name": "trial: physical input order is irrelevant",
      "kind": "trial",
      "visible": true,
      "input": {
        "tables": {
          "UserActivity": [
            {
              "username": "Eve",
              "activity": "Latest",
              "startDate": "2023-12-01",
              "endDate": "2023-12-02"
            },
            {
              "username": "Eve",
              "activity": "Earliest",
              "startDate": "2021-01-01",
              "endDate": "2021-01-02"
            },
            {
              "username": "Eve",
              "activity": "Middle",
              "startDate": "2022-07-01",
              "endDate": "2022-07-02"
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "username",
          "activity",
          "startDate",
          "endDate"
        ],
        "rows": [
          [
            "Eve",
            "Middle",
            "2022-07-01",
            "2022-07-02"
          ]
        ]
      },
      "tags": [
        "trial",
        "ordering"
      ]
    },
    {
      "id": "trial-two-users",
      "name": "trial: partitions rank independently",
      "kind": "trial",
      "visible": true,
      "input": {
        "tables": {
          "UserActivity": [
            {
              "username": "A",
              "activity": "A1",
              "startDate": "2020-01-01",
              "endDate": "2020-01-02"
            },
            {
              "username": "A",
              "activity": "A2",
              "startDate": "2020-02-01",
              "endDate": "2020-02-02"
            },
            {
              "username": "B",
              "activity": "B1",
              "startDate": "2018-01-01",
              "endDate": "2018-01-02"
            },
            {
              "username": "B",
              "activity": "B2",
              "startDate": "2019-01-01",
              "endDate": "2019-01-02"
            },
            {
              "username": "B",
              "activity": "B3",
              "startDate": "2020-01-01",
              "endDate": "2020-01-02"
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "username",
          "activity",
          "startDate",
          "endDate"
        ],
        "rows": [
          [
            "A",
            "A1",
            "2020-01-01",
            "2020-01-02"
          ],
          [
            "B",
            "B2",
            "2019-01-01",
            "2019-01-02"
          ]
        ]
      },
      "tags": [
        "trial",
        "partitions"
      ]
    },
