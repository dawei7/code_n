  "schema_version": 1,
  "challenge_id": "lc_1906",
  "cases": [
    {"id":"example-four-ranges","name":"sample: four ranges have different adjacent gaps","kind":"sample","visible":true,"input":{"nums":[1,3,4,8],"queries":[[0,1],[1,2],[2,3],[0,3]]},"expected":[2,1,4,1],"tags":["sample","multiple-queries"]},
    {"id":"example-duplicates","name":"sample: duplicates do not create a zero difference","kind":"sample","visible":true,"input":{"nums":[4,5,2,2,7,10],"queries":[[2,3],[0,2],[0,5],[3,5]]},"expected":[-1,1,1,3],"tags":["sample","duplicates"]},
    {"id":"trial-all-same","name":"one repeated value has no valid unequal pair","kind":"trial","visible":true,"input":{"nums":[1,1,1],"queries":[[0,2]]},"expected":[-1],"tags":["all-equal","minus-one"]},
    {"id":"trial-domain-extremes","name":"the value-domain extremes differ by ninety-nine","kind":"trial","visible":true,"input":{"nums":[1,100],"queries":[[0,1]]},"expected":[99],"tags":["domain-boundary","two-values"]},
    {"id":"real-duplicate-and-third","name":"hidden: repeated ones and one four produce a gap of three","kind":"real","visible":false,"input":{"nums":[1,1,4],"queries":[[0,2],[0,1],[1,2]]},"expected":[3,-1,3],"tags":["duplicates","range-boundaries"]},
    {"id":"real-localized-ranges","name":"hidden: overlapping ranges expose different present values","kind":"real","visible":false,"input":{"nums":[10,20,30,21,11],"queries":[[0,4],[0,2],[1,3],[3,4]]},"expected":[1,10,1,10],"tags":["overlapping-queries","localized"]},
    {"id":"real-consecutive-values","name":"hidden: any consecutive pair makes the answer one","kind":"real","visible":false,"input":{"nums":[8,2,9,50,3],"queries":[[0,2],[1,4],[3,4]]},"expected":[1,1,47],"tags":["consecutive-values","mixed-gaps"]},
    {"id":"real-query-length-two-same","name":"hidden: a two-position range may still contain one distinct value","kind":"real","visible":false,"input":{"nums":[7,7,9,12],"queries":[[0,1],[1,2],[2,3]]},"expected":[-1,2,3],"tags":["minimum-range","duplicates"]},
    {"id":"real-many-copies","name":"hidden: multiplicity never changes the distinct-value gaps","kind":"real","visible":false,"input":{"nums":[5,5,5,15,15,25,25,25],"queries":[[0,7],[0,4],[3,7],[4,5]]},"expected":[10,10,10,10],"tags":["many-duplicates","uniform-gap"]},
    {"id":"real-unsorted-values","name":"hidden: value order in nums does not affect sorted gaps","kind":"real","visible":false,"input":{"nums":[100,1,60,40,20,80],"queries":[[0,5],[1,4],[2,5]]},"expected":[19,19,20],"tags":["unsorted","domain-extremes"]},
    {"id":"real-single-query-wide","name":"hidden: a wide query with sparse values uses the smallest adjacent gap","kind":"real","visible":false,"input":{"nums":[2,2,98,50,51,75,25,2],"queries":[[0,7]]},"expected":[1],"tags":["wide-range","sparse-values"]}
  ]
