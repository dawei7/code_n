    {
      "id": "sample-1",
      "name": "sample: two words match a repeated suffix",
      "kind": "sample",
      "visible": true,
      "input": {
        "words": [
          "abc",
          "deq",
          "mee",
          "aqq",
          "dkd",
          "ccc"
        ],
        "pattern": "abb"
      },
      "expected": [
        "mee",
        "aqq"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "sample",
        "repeated-letter"
      ]
    },
