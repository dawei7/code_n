  "cases": [
    {
      "id": "sample-mixed-accounts",
      "name": "sample: two active accounts have no 2021 stream",
      "kind": "sample",
      "visible": true,
      "input": {"tables": {
        "Subscriptions": [
          {"account_id": 9, "start_date": "2020-02-18", "end_date": "2021-10-30"},
          {"account_id": 3, "start_date": "2021-09-21", "end_date": "2021-11-13"},
          {"account_id": 11, "start_date": "2020-02-28", "end_date": "2020-08-18"},
          {"account_id": 13, "start_date": "2021-04-20", "end_date": "2021-09-22"},
          {"account_id": 4, "start_date": "2020-10-26", "end_date": "2021-05-08"},
          {"account_id": 5, "start_date": "2020-09-11", "end_date": "2021-01-17"}
        ],
        "Streams": [
          {"session_id": 14, "account_id": 9, "stream_date": "2020-05-16"},
          {"session_id": 16, "account_id": 3, "stream_date": "2021-10-27"},
          {"session_id": 18, "account_id": 11, "stream_date": "2020-04-29"},
          {"session_id": 17, "account_id": 13, "stream_date": "2021-08-08"},
          {"session_id": 19, "account_id": 4, "stream_date": "2020-12-31"},
          {"session_id": 13, "account_id": 5, "stream_date": "2021-01-05"}
        ]
      }},
      "expected": {"columns": ["accounts_count"], "rows": [[2]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["sample", "mixed"]
    },
    {
      "id": "trial-year-boundaries",
      "name": "subscriptions touching either boundary qualify",
      "kind": "trial",
      "visible": true,
      "input": {"tables": {
        "Subscriptions": [
          {"account_id": 1, "start_date": "2020-01-01", "end_date": "2021-01-01"},
          {"account_id": 2, "start_date": "2021-12-31", "end_date": "2022-01-02"}
        ],
        "Streams": [
          {"session_id": 1, "account_id": 1, "stream_date": "2020-12-31"}
        ]
      }},
      "expected": {"columns": ["accounts_count"], "rows": [[2]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["boundary-dates"]
    },
    {
      "id": "trial-outside-stream",
      "name": "an out-of-year session does not disqualify",
      "kind": "trial",
      "visible": true,
      "input": {"tables": {
        "Subscriptions": [
          {"account_id": 1, "start_date": "2021-03-01", "end_date": "2021-09-01"}
        ],
        "Streams": [
          {"session_id": 1, "account_id": 1, "stream_date": "2020-12-31"}
        ]
      }},
      "expected": {"columns": ["accounts_count"], "rows": [[1]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["stream-date"]
    },
    {
      "id": "real-stream-on-first-day",
      "name": "hidden: a stream on January first disqualifies",
      "kind": "real",
      "visible": false,
      "input": {"tables": {
        "Subscriptions": [
          {"account_id": 1, "start_date": "2020-05-01", "end_date": "2022-05-01"}
        ],
        "Streams": [
          {"session_id": 1, "account_id": 1, "stream_date": "2021-01-01"}
        ]
      }},
      "expected": {"columns": ["accounts_count"], "rows": [[0]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["hidden", "stream-boundary"]
    },
    {
      "id": "real-no-overlapping-subscription",
      "name": "hidden: accounts outside 2021 are ignored",
      "kind": "real",
      "visible": false,
      "input": {"tables": {
        "Subscriptions": [
          {"account_id": 1, "start_date": "2019-01-01", "end_date": "2020-12-31"},
