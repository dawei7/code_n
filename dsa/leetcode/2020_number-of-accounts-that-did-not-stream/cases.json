      }},
      "expected": {"columns": ["accounts_count"], "rows": [[0]]},
      "validator": {"kind": "unordered_table"},
      "tags": ["hidden", "subscription-overlap"]
    },
    {
      "id": "real-multiple-streams-one-account",
      "name": "hidden: multiple sessions still exclude one account once",
