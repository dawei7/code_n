      "expected": ["ab", "aba", "ababa"],
      "validator": {"kind": "unordered_list"},
      "tags": ["hidden", "many-pieces"]
    },
    {
      "id": "hidden-overlapping-prefixes",
      "name": "hidden: overlapping component lengths",
