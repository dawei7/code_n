      "kind": "sample",
      "visible": true,
      "input": {"words": ["cat", "dog", "catdog"]},
      "expected": ["catdog"],
      "validator": {"kind": "unordered_list"},
      "tags": ["sample", "two-pieces"]
    },
    {
      "id": "sample-reused-piece",
      "name": "sample: one component may be reused",
      "kind": "sample",
      "visible": true,
      "input": {"words": ["a", "aa", "aaa"]},
      "expected": ["aa", "aaa"],
      "validator": {"kind": "unordered_list"},
      "tags": ["sample", "reuse"]
    },
    {
      "id": "trial-no-results",
      "name": "trial: no word decomposes",
