      "input": {
        "words": [
          "a",
          "aa",
          "aaa",
          "aaab"
        ]
      },
      "expected": [
        "aa",
        "aaa"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "benchmark",
        "scaling",
        "overlapping-prefixes"
      ]
