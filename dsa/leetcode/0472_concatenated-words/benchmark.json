{
  "schema_version": 1,
  "challenge_id": "lc_472",
  "measurement_note": "Size is the longest candidate length. Dynamic programming visits each suffix boundary once per word, while an unmemoized decomposition search recomputes the failing near-word suffix after exponentially many combinations of overlapping a-prefixes.",
