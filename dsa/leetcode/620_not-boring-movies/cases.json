    {"id": "sample-1", "name": "sample: filter and sort qualifying movies", "kind": "sample", "visible": true, "input": {"tables": {"Cinema": [{"id": 1, "movie": "War", "description": "great 3D", "rating": 8.9}, {"id": 2, "movie": "Science", "description": "fiction", "rating": 8.5}, {"id": 3, "movie": "irish", "description": "boring", "rating": 6.2}, {"id": 4, "movie": "Ice song", "description": "Fantacy", "rating": 8.6}, {"id": 5, "movie": "House card", "description": "Interesting", "rating": 9.1}]}}, "expected": {"columns": ["id", "movie", "description", "rating"], "rows": [[5, "House card", "Interesting", 9.1], [1, "War", "great 3D", 8.9]]}, "tags": ["sample", "filter-sort"]},
    {"id": "sample-2", "name": "sample: no qualifying movie", "kind": "sample", "visible": true, "input": {"tables": {"Cinema": [{"id": 1, "movie": "A", "description": "boring", "rating": 10.0}, {"id": 2, "movie": "B", "description": "great", "rating": 9.0}]}}, "expected": {"columns": ["id", "movie", "description", "rating"], "rows": []}, "tags": ["sample", "empty-result"]},
    {"id": "sample-3", "name": "sample: one qualifying row", "kind": "sample", "visible": true, "input": {"tables": {"Cinema": [{"id": 7, "movie": "Solo", "description": "fine", "rating": 7.5}]}}, "expected": {"columns": ["id", "movie", "description", "rating"], "rows": [[7, "Solo", "fine", 7.5]]}, "tags": ["sample", "single-row"]},
    {"id": "trial-1", "name": "trial: even high rating remains excluded", "kind": "trial", "visible": true, "input": {"tables": {"Cinema": [{"id": 2, "movie": "Even", "description": "excellent", "rating": 10.0}, {"id": 3, "movie": "Odd", "description": "good", "rating": 1.0}]}}, "expected": {"columns": ["id", "movie", "description", "rating"], "rows": [[3, "Odd", "good", 1.0]]}, "tags": ["trial", "odd-id"]},
    {"id": "trial-2", "name": "trial: deterministic rating tie", "kind": "trial", "visible": true, "input": {"tables": {"Cinema": [{"id": 9, "movie": "Nine", "description": "good", "rating": 8.0}, {"id": 3, "movie": "Three", "description": "good", "rating": 8.0}, {"id": 5, "movie": "Five", "description": "good", "rating": 9.0}]}}, "expected": {"columns": ["id", "movie", "description", "rating"], "rows": [[5, "Five", "good", 9.0], [3, "Three", "good", 8.0], [9, "Nine", "good", 8.0]]}, "tags": ["trial", "tie"]},
    {"id": "hidden-1", "name": "hidden: boring filter is independent of movie title", "kind": "real", "visible": false, "input": {"tables": {"Cinema": [{"id": 1, "movie": "boring", "description": "interesting", "rating": 5.0}, {"id": 3, "movie": "Exciting", "description": "boring", "rating": 9.0}, {"id": 5, "movie": "Other", "description": "nice", "rating": 6.0}]}}, "expected": {"columns": ["id", "movie", "description", "rating"], "rows": [[5, "Other", "nice", 6.0], [1, "boring", "interesting", 5.0]]}, "tags": ["hidden", "description-column"]},
    {"id": "hidden-2", "name": "hidden: mixed ratings and excluded rows", "kind": "real", "visible": false, "input": {"tables": {"Cinema": [{"id": 11, "movie": "A", "description": "ok", "rating": 2.5}, {"id": 13, "movie": "B", "description": "ok", "rating": 9.5}, {"id": 15, "movie": "C", "description": "boring", "rating": 10.0}, {"id": 16, "movie": "D", "description": "ok", "rating": 8.0}, {"id": 17, "movie": "E", "description": "ok", "rating": 7.0}]}}, "expected": {"columns": ["id", "movie", "description", "rating"], "rows": [[13, "B", "ok", 9.5], [17, "E", "ok", 7.0], [11, "A", "ok", 2.5]]}, "tags": ["hidden", "mixed"]}
