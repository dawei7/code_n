        {"account_id":4,"day":"2024-04-04","type":"Deposit","amount":1}
      ]}},
      "expected":{"columns":["account_id","day","balance"],"rows":[[4,"2024-04-01",5],[4,"2024-04-02",12],[4,"2024-04-03",9],[4,"2024-04-04",10]]},
