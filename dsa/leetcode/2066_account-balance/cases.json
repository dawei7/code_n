    {
      "id": "real-input-order",
      "name": "hidden: calculation and output ignore input row order",
      "kind": "real",
      "visible": false,
      "input":{"tables":{"Transactions":[
        {"account_id":2,"day":"2024-02-03","type":"Withdraw","amount":3},
        {"account_id":1,"day":"2024-01-02","type":"Deposit","amount":4},
        {"account_id":2,"day":"2024-02-01","type":"Deposit","amount":10},
        {"account_id":1,"day":"2024-01-05","type":"Withdraw","amount":1}
      ]}},
      "expected":{"columns":["account_id","day","balance"],"rows":[[1,"2024-01-02",4],[1,"2024-01-05",3],[2,"2024-02-01",10],[2,"2024-02-03",7]]},
      "validator":{"kind":"ordered_table"},
      "tags":["hidden","ordering","partitions"]
    },
