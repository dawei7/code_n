      "expected": "7",
      "tags": ["trial", "single"]
    },
    {
      "id": "trial-right-associative",
      "name": "trial: nested false branch is evaluated first",
      "kind": "trial",
      "visible": true,
      "input": {"expression": "F?0:F?1:2"},
      "expected": "2",
      "tags": ["trial", "associativity"]
    },
    {
      "id": "hidden-boolean-value",
