      "expected": "4",
      "tags": ["sample", "false-branch"]
    },
    {
      "id": "sample-3",
      "name": "sample: true branch contains another ternary",
      "kind": "sample",
      "visible": true,
      "input": {"expression": "T?T?F:5:3"},
      "expected": "F",
      "tags": ["sample", "true-branch"]
    },
    {
      "id": "trial-single",
      "name": "trial: one terminal operand",
