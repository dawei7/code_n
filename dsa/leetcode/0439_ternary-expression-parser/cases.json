      "expected": "2",
      "tags": ["hidden", "mixed"]
    },
    {
      "id": "hidden-deep-false",
      "name": "hidden: several false choices descend right",
      "kind": "real",
      "visible": false,
      "input": {"expression": "F?1:F?2:F?3:4"},
      "expected": "4",
      "tags": ["hidden", "deep"]
