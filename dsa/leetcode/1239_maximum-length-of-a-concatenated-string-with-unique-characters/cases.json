{
  "schema_version": 1,
  "challenge_id": "lc_1239",
  "cases": [
    {
      "id": "sample-short-words",
      "name": "sample: choose either of two four-letter concatenations",
      "kind": "sample",
      "visible": true,
      "input": {
        "arr": [
          "un",
          "iq",
          "ue"
        ]
      },
      "expected": 4,
      "tags": [
        "sample",
        "overlap"
      ]
    },
    {
      "id": "sample-longer-words",
      "name": "sample: combine compatible longer strings",
      "kind": "sample",
      "visible": true,
      "input": {
        "arr": [
          "cha",
          "r",
          "act",
          "ers"
        ]
      },
      "expected": 6,
      "tags": [
        "sample",
        "backtracking"
      ]
    },
    {
      "id": "sample-alphabet",
      "name": "sample: one word contains the full alphabet",
      "kind": "sample",
      "visible": true,
      "input": {
        "arr": [
          "abcdefghijklmnopqrstuvwxyz"
        ]
      },
      "expected": 26,
      "tags": [
        "sample",
        "full-alphabet"
      ]
    },
    {
      "id": "trial-all-invalid",
      "name": "all words repeat characters internally",
      "kind": "trial",
      "visible": true,
      "input": {
        "arr": [
          "aa",
          "bb",
          "cc"
        ]
      },
      "expected": 0,
      "tags": [
        "internal-duplicates"
      ]
    },
    {
      "id": "trial-disjoint",
      "name": "all pairwise-disjoint words may be selected",
      "kind": "trial",
      "visible": true,
      "input": {
        "arr": [
          "ab",
          "cd",
          "efg"
        ]
      },
      "expected": 7,
      "tags": [
        "disjoint"
      ]
    },
    {
      "id": "real-mixed-invalid",
      "name": "hidden: ignore invalid words among useful choices",
      "kind": "real",
      "visible": false,
      "input": {
        "arr": [
          "ab",
          "cc",
          "def",
          "fa",
          "zz"
        ]
      },
      "expected": 5,
      "tags": [
        "hidden",
        "mixed-validity"
      ]
    },
    {
      "id": "real-order-independent-length",
      "name": "hidden: overlaps force a nonadjacent subsequence",
      "kind": "real",
      "visible": false,
      "input": {
        "arr": [
          "abc",
          "de",
          "cdef",
          "gh",
          "aij"
        ]
      },
      "expected": 9,
      "tags": [
        "hidden",
        "overlap"
      ]
    }
  ]
