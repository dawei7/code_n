      "visible": false,
      "input": {"operations": [["inc", "a"], ["inc", "b"], ["inc", "b"], ["inc", "c"], ["inc", "c"], ["inc", "c"], ["dec", "c"], ["dec", "b"], ["getMaxKey"], ["getMinKey"]]},
      "expected": ["c", "a"],
      "validator": {"kind": "all_one_trace"},
