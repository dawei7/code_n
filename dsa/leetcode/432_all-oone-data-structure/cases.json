      "kind": "trial",
      "visible": true,
      "input": {"operations": [["inc", "a"], ["inc", "a"], ["inc", "b"], ["inc", "b"], ["inc", "b"], ["dec", "b"], ["dec", "a"], ["getMaxKey"], ["getMinKey"]]},
      "expected": ["b", "a"],
      "validator": {"kind": "all_one_trace"},
      "tags": ["trial", "decrement"]
    },
    {
      "id": "hidden-bucket-removal",
      "name": "hidden: empty middle buckets are removed",
