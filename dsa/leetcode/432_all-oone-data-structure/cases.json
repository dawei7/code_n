      "visible": true,
      "input": {"operations": [["getMaxKey"], ["getMinKey"]]},
      "expected": ["", ""],
      "validator": {"kind": "all_one_trace"},
      "tags": ["sample", "empty"]
    },
    {
      "id": "sample-3",
      "name": "sample: two keys tie",
      "kind": "sample",
      "visible": true,
      "input": {"operations": [["inc", "a"], ["inc", "b"], ["getMaxKey"], ["getMinKey"]]},
      "expected": ["a", "b"],
      "validator": {"kind": "all_one_trace"},
      "tags": ["sample", "tie"]
    },
    {
