      "tags": ["hidden", "rejection-state"]
    },
    {
      "id": "real-already-indirectly-connected",
      "name": "hidden: a redundant edge inside one component succeeds",
      "kind": "real",
      "visible": false,
      "input": {
        "n": 4,
        "restrictions": [[0, 3]],
        "requests": [[0, 1], [1, 2], [0, 2], [2, 3]]
