{
  "schema_version": 1,
  "challenge_id": "lc_606",
  "cases": [
    {
      "id": "sample-1",
      "name": "sample: omit unnecessary empty right children",
      "kind": "sample",
      "visible": true,
      "input": {
        "root": [
          1,
          2,
          3,
          4
        ]
      },
      "expected": "1(2(4))(3)",
      "tags": [
        "sample",
        "left-child"
      ]
    },
    {
      "id": "sample-2",
      "name": "sample: preserve empty left before right child",
      "kind": "sample",
      "visible": true,
      "input": {
        "root": [
          1,
          2,
          3,
          null,
          4
        ]
      },
      "expected": "1(2()(4))(3)",
      "tags": [
        "sample",
        "empty-left"
      ]
    },
    {
      "id": "sample-3",
      "name": "sample: root has only a right child",
      "kind": "sample",
      "visible": true,
      "input": {
        "root": [
          1,
          null,
          2
        ]
      },
      "expected": "1()(2)",
      "tags": [
        "sample",
        "right-only"
      ]
    },
    {
      "id": "trial-1",
      "name": "trial: one node",
      "kind": "trial",
      "visible": true,
      "input": {
        "root": [
          7
        ]
      },
      "expected": "7",
      "tags": [
        "trial",
        "leaf"
      ]
    },
    {
      "id": "trial-2",
      "name": "trial: root has only a left child",
      "kind": "trial",
      "visible": true,
      "input": {
        "root": [
          1,
          2
        ]
      },
      "expected": "1(2)",
      "tags": [
        "trial",
        "left-only"
      ]
    },
    {
      "id": "hidden-1",
      "name": "hidden: negative values and both child positions",
      "kind": "real",
      "visible": false,
      "input": {
        "root": [
          -1,
          -2,
          3,
          null,
          null,
          4,
          -5
        ]
      },
      "expected": "-1(-2)(3(4)(-5))",
      "tags": [
        "hidden",
        "negative"
      ]
    },
    {
      "id": "hidden-2",
      "name": "hidden: nested right-only links",
      "kind": "real",
      "visible": false,
      "input": {
        "root": [
          1,
          null,
          2,
          null,
