{
  "schema_version": 1,
  "challenge_id": "lc_1233",
  "cases": [
    {
      "id": "sample-multiple-roots",
      "name": "sample: remove descendants under two roots",
      "kind": "sample",
      "visible": true,
      "input": {
        "folder": [
          "/a",
          "/a/b",
          "/c/d",
          "/c/d/e",
          "/c/f"
        ]
      },
      "expected": [
        "/a",
        "/c/d",
        "/c/f"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "sample",
        "multiple-roots"
      ]
    },
    {
      "id": "sample-single-root",
      "name": "sample: one root removes two deep descendants",
      "kind": "sample",
      "visible": true,
      "input": {
        "folder": [
          "/a",
          "/a/b/c",
          "/a/b/d"
        ]
      },
      "expected": [
        "/a"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "sample",
        "deep-descendants"
      ]
    },
    {
      "id": "sample-similar-names",
      "name": "sample: similar component names remain independent",
      "kind": "sample",
      "visible": true,
      "input": {
        "folder": [
          "/a/b/c",
          "/a/b/ca",
          "/a/b/d"
        ]
      },
      "expected": [
        "/a/b/c",
        "/a/b/ca",
        "/a/b/d"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "sample",
        "prefix-boundary"
      ]
    },
    {
      "id": "trial-single",
      "name": "a single listed path has no parent",
      "kind": "trial",
      "visible": true,
      "input": {
        "folder": [
          "/only"
        ]
      },
      "expected": [
        "/only"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "single-path"
      ]
    },
    {
      "id": "trial-deep-chain",
      "name": "only the shortest folder in a deep chain remains",
      "kind": "trial",
      "visible": true,
      "input": {
        "folder": [
          "/a/b/c/d",
          "/a/b",
          "/a",
          "/a/b/c"
        ]
      },
      "expected": [
        "/a"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "deep-chain",
        "unsorted-input"
      ]
    },
    {
      "id": "real-prefix-trap",
      "name": "hidden: textual prefixes without slash boundaries remain",
      "kind": "real",
      "visible": false,
      "input": {
        "folder": [
          "/a",
          "/ab",
          "/a/b",
          "/abc/d",
          "/abc"
        ]
      },
      "expected": [
        "/a",
        "/ab",
        "/abc"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "hidden",
        "prefix-boundary"
      ]
    },
    {
      "id": "real-interleaved-roots",
      "name": "hidden: unordered descendants under several roots",
      "kind": "real",
      "visible": false,
      "input": {
        "folder": [
          "/m/n/o",
          "/z/a",
          "/b",
          "/m",
          "/z",
          "/ba/c",
          "/ba"
        ]
      },
      "expected": [
        "/b",
        "/ba",
        "/m",
        "/z"
      ],
      "validator": {
        "kind": "unordered_list"
      },
      "tags": [
        "hidden",
        "multiple-roots"
      ]
    }
  ]
}
