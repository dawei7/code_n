{
  "schema_version": 1,
  "challenge_id": "lc_1788",
  "cases": [
    {
      "id": "example-overlapping-endpoints",
      "name": "later value produces the best equal endpoints",
      "kind": "sample",
      "visible": true,
      "input": {"flowers": [1,2,3,1,2]},
      "expected": 8,
      "tags": ["example", "positive-interior"]
    },
    {
      "id": "example-remove-negative",
      "name": "negative interior flower is removed",
      "kind": "sample",
      "visible": true,
      "input": {"flowers": [100,1,1,-3,1]},
      "expected": 3,
      "tags": ["example", "negative-interior"]
    },
    {
      "id": "example-negative-answer",
      "name": "valid garden may have negative maximum beauty",
      "kind": "sample",
      "visible": true,
      "input": {"flowers": [-1,-2,0,-1]},
      "expected": -2,
      "tags": ["example", "negative-answer"]
    },
    {
      "id": "trial-two-flowers",
      "name": "equal positive endpoints form the minimum valid garden",
      "kind": "trial",
      "visible": true,
      "input": {"flowers": [5,5]},
      "expected": 10,
      "tags": ["minimum-length", "positive-endpoints"]
    },
    {
      "id": "real-negative-endpoints",
      "name": "hidden: positive interior outweighs negative endpoints",
      "kind": "real",
      "visible": false,
      "input": {"flowers": [-2,10,-5,9,-2]},
      "expected": 15,
      "tags": ["negative-endpoints", "positive-interior"]
    },
    {
      "id": "real-zero-endpoints",
      "name": "hidden: zero endpoints retain positive interior beauty",
      "kind": "real",
      "visible": false,
      "input": {"flowers": [0,-3,4,0]},
      "expected": 4,
      "tags": ["zero-endpoints", "remove-negative"]
    },
    {
      "id": "real-several-equal-endpoints",
      "name": "hidden: later matching endpoint can include more positive beauty",
      "kind": "real",
      "visible": false,
      "input": {"flowers": [1,100,1,-10,1]},
      "expected": 103,
      "tags": ["repeated-value", "prefix"]
    },
    {
      "id": "real-all-negative",
      "name": "hidden: choose the least damaging repeated value",
      "kind": "real",
      "visible": false,
      "input": {"flowers": [-5,-1,-5,-1]},
      "expected": -2,
      "tags": ["all-negative", "endpoint-choice"]
    },
    {
      "id": "real-large-values",
      "name": "hidden: boundary values accumulate safely",
      "kind": "real",
      "visible": false,
      "input": {"flowers": [10000,10000,-10000,10000]},
      "expected": 30000,
      "tags": ["maximum-value", "large-sum"]
    }
  ]
}
