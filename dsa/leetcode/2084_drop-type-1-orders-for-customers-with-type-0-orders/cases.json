{
  "schema_version": 1,
  "challenge_id": "lc_2084",
  "cases": [
    {
      "id": "sample-mixed-customers",
      "name": "sample: apply type priority independently per customer",
      "kind": "sample",
      "visible": true,
      "input": {
        "tables": {
          "Orders": [
            {"order_id": 1, "customer_id": 1, "order_type": 0},
            {"order_id": 2, "customer_id": 1, "order_type": 0},
            {"order_id": 11, "customer_id": 2, "order_type": 0},
            {"order_id": 12, "customer_id": 2, "order_type": 1},
            {"order_id": 21, "customer_id": 3, "order_type": 1},
            {"order_id": 22, "customer_id": 3, "order_type": 0},
            {"order_id": 31, "customer_id": 4, "order_type": 1},
            {"order_id": 32, "customer_id": 4, "order_type": 1}
          ]
        }
      },
      "expected": {
        "columns": ["order_id", "customer_id", "order_type"],
        "rows": [[1, 1, 0], [2, 1, 0], [11, 2, 0], [22, 3, 0], [31, 4, 1], [32, 4, 1]]
      },
      "validator": {"kind": "unordered_table"},
      "tags": ["sample", "mixed-customers"]
    },
    {
      "id": "trial-only-type-one",
      "name": "all type one orders remain when no preferred type exists",
      "kind": "trial",
      "visible": true,
      "input": {
        "tables": {
          "Orders": [
            {"order_id": 5, "customer_id": 7, "order_type": 1},
            {"order_id": 6, "customer_id": 7, "order_type": 1}
          ]
        }
      },
      "expected": {
        "columns": ["order_id", "customer_id", "order_type"],
        "rows": [[5, 7, 1], [6, 7, 1]]
      },
      "validator": {"kind": "unordered_table"},
      "tags": ["only-type-one"]
    },
    {
      "id": "trial-multiple-type-zero",
      "name": "all preferred orders remain while type one is dropped",
      "kind": "trial",
      "visible": true,
      "input": {
        "tables": {
          "Orders": [
            {"order_id": 8, "customer_id": 2, "order_type": 1},
            {"order_id": 9, "customer_id": 2, "order_type": 0},
            {"order_id": 10, "customer_id": 2, "order_type": 0}
          ]
        }
      },
      "expected": {
        "columns": ["order_id", "customer_id", "order_type"],
        "rows": [[9, 2, 0], [10, 2, 0]]
      },
      "validator": {"kind": "unordered_table"},
      "tags": ["multiple-type-zero"]
    },
    {
      "id": "real-one-order-per-customer",
      "name": "hidden: singleton customer partitions always keep their row",
      "kind": "real",
      "visible": false,
      "input": {
        "tables": {
          "Orders": [
            {"order_id": 20, "customer_id": 100, "order_type": 0},
            {"order_id": 21, "customer_id": 200, "order_type": 1}
          ]
        }
      },
      "expected": {
        "columns": ["order_id", "customer_id", "order_type"],
        "rows": [[20, 100, 0], [21, 200, 1]]
      },
      "validator": {"kind": "unordered_table"},
      "tags": ["hidden", "singleton-partitions"]
    },
    {
      "id": "real-input-order-does-not-matter",
      "name": "hidden: a later type zero suppresses an earlier type one",
      "kind": "real",
      "visible": false,
      "input": {
        "tables": {
          "Orders": [
            {"order_id": 30, "customer_id": 9, "order_type": 1},
            {"order_id": 31, "customer_id": 8, "order_type": 1},
            {"order_id": 32, "customer_id": 9, "order_type": 0},
            {"order_id": 33, "customer_id": 8, "order_type": 1}
          ]
        }
      },
      "expected": {
        "columns": ["order_id", "customer_id", "order_type"],
        "rows": [[31, 8, 1], [32, 9, 0], [33, 8, 1]]
      },
      "validator": {"kind": "unordered_table"},
      "tags": ["hidden", "input-order"]
    },
    {
      "id": "real-several-mixed-partitions",
      "name": "hidden: each customer receives an independent minimum type",
      "kind": "real",
      "visible": false,
      "input": {
        "tables": {
          "Orders": [
            {"order_id": 40, "customer_id": 1, "order_type": 1},
            {"order_id": 41, "customer_id": 1, "order_type": 0},
            {"order_id": 42, "customer_id": 2, "order_type": 1},
            {"order_id": 43, "customer_id": 3, "order_type": 0},
            {"order_id": 44, "customer_id": 3, "order_type": 1},
            {"order_id": 45, "customer_id": 2, "order_type": 1}
          ]
        }
      },
      "expected": {
        "columns": ["order_id", "customer_id", "order_type"],
        "rows": [[41, 1, 0], [42, 2, 1], [43, 3, 0], [45, 2, 1]]
      },
      "validator": {"kind": "unordered_table"},
      "tags": ["hidden", "partition-isolation"]
    }
  ]
}
