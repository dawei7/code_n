    {"id": "real-right-trim", "name": "hidden: only the right side is removed", "kind": "real", "visible": false, "input": {"intervals": [[-10,-2],[1,4]], "to_be_removed": [-5,0]}, "expected": [[-10,-5],[1,4]], "tags": ["hidden", "right-trim"]},
    {"id": "real-exact-match", "name": "hidden: exact interval match disappears", "kind": "real", "visible": false, "input": {"intervals": [[1,3],[5,8]], "to_be_removed": [5,8]}, "expected": [[1,3]], "tags": ["hidden", "exact-match"]}
