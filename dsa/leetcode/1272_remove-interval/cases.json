    {"id": "trial-touching-boundaries", "name": "trial: half-open boundaries only touch", "kind": "trial", "visible": true, "input": {"intervals": [[0,2],[3,5]], "to_be_removed": [2,3]}, "expected": [[0,2],[3,5]], "tags": ["trial", "half-open"]},
