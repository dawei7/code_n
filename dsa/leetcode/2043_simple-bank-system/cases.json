{
  "schema_version": 1,
  "challenge_id": "lc_2043",
  "cases": [
    {
      "id": "sample-mixed-transactions",
      "name": "sample: valid updates followed by two failures",
      "kind": "sample",
      "visible": true,
      "input": {
        "operations": ["Bank", "withdraw", "transfer", "deposit", "transfer", "withdraw"],
        "arguments": [[[10, 100, 20, 50, 30]], [3, 10], [5, 1, 20], [5, 20], [3, 4, 15], [10, 50]]
      },
      "expected": [null, true, true, true, false, false],
      "tags": ["sample", "all-operations", "invalid-account"]
    },
    {
      "id": "trial-deposit-then-insufficient",
      "name": "a deposit still leaves an excessive withdrawal invalid",
      "kind": "trial",
      "visible": true,
      "input": {
        "operations": ["Bank", "deposit", "withdraw"],
        "arguments": [[[5]], [1, 4], [1, 10]]
      },
      "expected": [null, true, false],
      "tags": ["deposit", "insufficient-funds"]
    },
    {
      "id": "trial-transfer-then-withdraw",
      "name": "a recipient can spend transferred funds",
      "kind": "trial",
      "visible": true,
      "input": {
        "operations": ["Bank", "transfer", "withdraw"],
        "arguments": [[[8, 2]], [1, 2, 3], [2, 4]]
      },
      "expected": [null, true, true],
      "tags": ["transfer", "state"]
    },
    {
      "id": "real-invalid-destination-is-atomic",
      "name": "hidden: failed transfer preserves the valid source balance",
      "kind": "real",
      "visible": false,
      "input": {
        "operations": ["Bank", "transfer", "withdraw"],
        "arguments": [[[10]], [1, 2, 5], [1, 10]]
      },
      "expected": [null, false, true],
      "tags": ["hidden", "atomic-failure", "invalid-destination"]
    },
    {
      "id": "real-exact-balance-and-zero",
      "name": "hidden: exact and zero withdrawals are valid",
      "kind": "real",
      "visible": false,
      "input": {
        "operations": ["Bank", "withdraw", "withdraw", "deposit"],
        "arguments": [[[7]], [1, 7], [1, 0], [1, 0]]
      },
      "expected": [null, true, true, true],
      "tags": ["hidden", "exact-balance", "zero-money"]
    },
    {
      "id": "real-self-transfer",
      "name": "hidden: a self-transfer preserves available funds",
      "kind": "real",
      "visible": false,
      "input": {
        "operations": ["Bank", "transfer", "withdraw"],
        "arguments": [[[7]], [1, 1, 7], [1, 7]]
      },
      "expected": [null, true, true],
      "tags": ["hidden", "self-transfer"]
    },
    {
      "id": "real-money-boundary",
      "name": "hidden: balances can grow beyond the transaction bound",
      "kind": "real",
      "visible": false,
      "input": {
        "operations": ["Bank", "deposit", "transfer", "withdraw"],
        "arguments": [[[1000000000000, 0]], [1, 1000000000000], [1, 2, 1500000000000], [2, 1500000000000]]
      },
      "expected": [null, true, true, true],
      "tags": ["hidden", "money-boundary", "wide-balance"]
    }
  ]
}
