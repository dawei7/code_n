  "cases": [
    {"id":"sample-three-progressions","name":"sample: three starts and steps select different progressions","kind":"sample","visible":true,"input":{"nums":[0,1,2,3,4,5,6,7],"queries":[[0,3],[5,1],[4,2]]},"expected":[9,18,10],"tags":["sample","multiple-steps"]},
    {"id":"sample-endpoint-pair","name":"sample: a large step selects the two endpoints","kind":"sample","visible":true,"input":{"nums":[100,200,101,201,102,202,103,203],"queries":[[0,7]]},"expected":[303],"tags":["sample","large-step"]},
    {"id":"trial-shared-step","name":"trial: different starts share one step relation","kind":"trial","visible":true,"input":{"nums":[1,2,3,4,5],"queries":[[0,2],[1,2],[4,1]]},"expected":[9,6,5],"tags":["shared-step","last-index"]},
    {"id":"trial-single-element","name":"trial: the only index forms every progression","kind":"trial","visible":true,"input":{"nums":[7],"queries":[[0,1]]},"expected":[7],"tags":["single-element","minimum"]},
    {"id":"trial-step-equals-length","name":"trial: a full-length step selects only its start","kind":"trial","visible":true,"input":{"nums":[4,5,6],"queries":[[0,3],[1,3],[2,3]]},"expected":[4,5,6],"tags":["large-step","single-term"]},
    {"id":"trial-repeated-queries","name":"trial: repeated queries preserve repeated outputs","kind":"trial","visible":true,"input":{"nums":[2,4,6,8],"queries":[[0,1],[0,1],[1,2]]},"expected":[20,20,12],"tags":["duplicates","query-order"]},
    {"id":"real-modulo","name":"hidden: long sums are reduced modulo the required constant","kind":"real","visible":false,"input":{"nums":[1000000000,1000000000,1000000000],"queries":[[0,1]]},"expected":[999999986],"tags":["modulo","large-values"]},
    {"id":"real-zero-values","name":"hidden: zeros remain part of the index progression","kind":"real","visible":false,"input":{"nums":[0,5,0,7,0,9],"queries":[[0,2],[1,2],[2,3]]},"expected":[0,21,9],"tags":["zero","multiple-steps"]},
    {"id":"real-original-order","name":"hidden: grouped steps return answers in original query order","kind":"real","visible":false,"input":{"nums":[1,2,4,8,16,32],"queries":[[0,5],[0,1],[1,3],[2,2]]},"expected":[33,63,18,20],"tags":["query-order","grouping"]},
    {"id":"real-large-start","name":"hidden: a late start shortens a small-step progression","kind":"real","visible":false,"input":{"nums":[3,1,4,1,5,9,2],"queries":[[5,1],[4,1],[3,2]]},"expected":[11,16,10],"tags":["late-start","small-step"]}
