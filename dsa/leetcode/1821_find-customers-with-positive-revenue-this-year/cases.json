        {"customer_id":11,"year":2021,"revenue":7},
        {"customer_id":11,"year":2022,"revenue":-9}
      ]}},
      "expected": {"columns":["customer_id"],"rows":[[11]]},
      "validator": {"kind":"unordered_table"},
      "tags": ["same-customer","historical-rows"]
    },
    {
      "id": "real-multiple-qualifiers",
      "name": "hidden: several customers qualify independently",
      "kind": "real",
      "visible": false,
      "input": {"tables":{"Customers":[
        {"customer_id":3,"year":2021,"revenue":2},
        {"customer_id":1,"year":2021,"revenue":5},
        {"customer_id":2,"year":2021,"revenue":4}
      ]}},
      "expected": {"columns":["customer_id"],"rows":[[1],[2],[3]]},
      "validator": {"kind":"unordered_table"},
      "tags": ["unordered-output","multiple-customers"]
    },
    {
      "id": "real-no-qualifiers",
