{
  "schema_version": 1,
  "challenge_id": "lc_1821",
  "cases": [
    {
      "id": "example-mixed-years-and-revenue",
      "name": "sample: only positive 2021 rows qualify",
      "kind": "sample",
      "visible": true,
      "input": {"tables":{"Customers":[
        {"customer_id":1,"year":2018,"revenue":50},
        {"customer_id":1,"year":2021,"revenue":30},
        {"customer_id":1,"year":2020,"revenue":70},
        {"customer_id":2,"year":2021,"revenue":-50},
        {"customer_id":3,"year":2018,"revenue":10},
        {"customer_id":3,"year":2016,"revenue":50},
        {"customer_id":4,"year":2021,"revenue":20}
      ]}},
      "expected": {"columns":["customer_id"],"rows":[[1],[4]]},
      "validator": {"kind":"unordered_table"},
      "tags": ["example","mixed-years","negative-revenue"]
    },
    {
      "id": "trial-zero-is-not-positive",
      "name": "zero revenue does not qualify",
      "kind": "trial",
      "visible": true,
      "input": {"tables":{"Customers":[{"customer_id":5,"year":2021,"revenue":0}]}},
      "expected": {"columns":["customer_id"],"rows":[]},
      "validator": {"kind":"unordered_table"},
      "tags": ["strict-comparison","zero-revenue"]
    },
    {
      "id": "trial-single-positive",
      "name": "one positive 2021 customer",
      "kind": "trial",
      "visible": true,
      "input": {"tables":{"Customers":[{"customer_id":8,"year":2021,"revenue":1}]}},
      "expected": {"columns":["customer_id"],"rows":[[8]]},
      "validator": {"kind":"unordered_table"},
      "tags": ["minimum-positive","single-row"]
    },
    {
      "id": "trial-positive-other-year",
      "name": "positive revenue in another year is excluded",
      "kind": "trial",
      "visible": true,
      "input": {"tables":{"Customers":[{"customer_id":9,"year":2020,"revenue":999}]}},
      "expected": {"columns":["customer_id"],"rows":[]},
      "validator": {"kind":"unordered_table"},
      "tags": ["year-filter","positive-other-year"]
    },
    {
      "id": "real-negative-and-positive-years",
      "name": "hidden: another year's positive value cannot offset 2021",
      "kind": "real",
      "visible": false,
      "input": {"tables":{"Customers":[
        {"customer_id":10,"year":2020,"revenue":100},
        {"customer_id":10,"year":2021,"revenue":-1}
      ]}},
      "expected": {"columns":["customer_id"],"rows":[]},
      "validator": {"kind":"unordered_table"},
      "tags": ["same-customer","negative-2021"]
    },
    {
      "id": "real-2021-positive-among-history",
