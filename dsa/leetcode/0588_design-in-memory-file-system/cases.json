        ],
        "one two",
        [
          "note"
        ]
      ],
      "tags": [
        "hidden",
        "root-file"
      ]
    },
    {
      "id": "hidden-2",
      "name": "hidden: shared path prefixes remain independent",
      "kind": "real",
      "visible": false,
      "input": {
        "operations": [
          [
            "mkdir",
            "/team/alpha"
          ],
          [
            "mkdir",
            "/team/alpine"
          ],
          [
            "addContentToFile",
            "/team/alpha/log",
            "A"
          ],
          [
            "addContentToFile",
            "/team/alpine/log",
            "B"
          ],
          [
            "ls",
            "/team"
          ],
          [
            "readContentFromFile",
            "/team/alpha/log"
          ],
          [
            "readContentFromFile",
            "/team/alpine/log"
          ]
        ]
      },
      "expected": [
        [
          "alpha",
          "alpine"
        ],
        "A",
        "B"
      ],
      "tags": [
