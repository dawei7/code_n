            },
            {
              "left_operand": "z",
              "operator": ">",
              "right_operand": "z"
            },
            {
              "left_operand": "z",
              "operator": "<",
              "right_operand": "z"
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "left_operand",
          "operator",
