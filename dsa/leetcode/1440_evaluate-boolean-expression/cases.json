{
  "schema_version": 1,
  "challenge_id": "lc_1440",
  "cases": [
    {
      "id": "sample-three-operators",
      "name": "sample: evaluate all supported operators",
      "kind": "sample",
      "visible": true,
      "input": {
        "tables": {
          "Variables": [
            {
              "name": "x",
              "value": 66
            },
            {
              "name": "y",
              "value": 77
            }
          ],
          "Expressions": [
            {
              "left_operand": "x",
              "operator": ">",
              "right_operand": "y"
            },
            {
              "left_operand": "x",
              "operator": "<",
              "right_operand": "y"
            },
            {
              "left_operand": "x",
              "operator": "=",
              "right_operand": "y"
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "left_operand",
          "operator",
          "right_operand",
          "value"
        ],
        "rows": [
          [
            "x",
            "<",
            "y",
            "true"
          ],
          [
            "x",
            "=",
            "y",
            "false"
          ],
          [
            "x",
            ">",
            "y",
            "false"
          ]
        ]
      },
      "tags": [
        "sample",
        "operators"
      ]
    },
    {
      "id": "sample-equal-values",
      "name": "sample: different names have equal values",
      "kind": "sample",
      "visible": true,
      "input": {
        "tables": {
          "Variables": [
            {
              "name": "a",
              "value": 5
            },
            {
              "name": "b",
              "value": 5
            }
          ],
          "Expressions": [
            {
              "left_operand": "a",
              "operator": "=",
              "right_operand": "b"
            },
            {
              "left_operand": "a",
              "operator": "<",
              "right_operand": "b"
            }
          ]
        }
      },
      "expected": {
        "columns": [
          "left_operand",
          "operator",
          "right_operand",
          "value"
        ],
        "rows": [
          [
            "a",
            "<",
            "b",
            "false"
          ],
          [
            "a",
            "=",
            "b",
            "true"
          ]
        ]
      },
      "tags": [
        "sample",
        "equality"
      ]
    },
