            },
            {
              "sales_id": 2,
              "name": "Bob",
              "salary": 50000,
              "commission_rate": 10,
              "hire_date": "2020-01-01"
            }
          ],
          "Company": [
            {
              "com_id": 1,
              "name": "RED",
              "city": "A"
            },
            {
              "com_id": 2,
              "name": "BLUE",
              "city": "B"
            }
          ],
          "Orders": [
            {
              "order_id": 1,
              "order_date": "2021-01-01",
              "com_id": 1,
              "sales_id": 1,
              "amount": 100
