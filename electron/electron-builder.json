{
  "appId": "com.dawei7.coden",
  "productName": "cOde(n)",
  "copyright": "Copyright © 2026 dawei7",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../server/dist/coden-server",
      "to": "coden-server"
    },
    {
      "from": "../web/dist",
      "to": "web-dist"
    }
  ],
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "assets/icon.ico"
  },
  "asar": true,
  "compression": "normal",
  "buildDependenciesFromSource": false,
  "publish": {
    "provider": "github",
    "owner": "dawei7",
    "repo": "code_n",
    "releaseType": "release",
    "channel": "latest"
  }
}
